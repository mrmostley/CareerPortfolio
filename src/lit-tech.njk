---
permalink: /lit-tech.html
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ littechPage.pageTitle }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Libre+Franklin:wght@300;400;500;600;700&family=Source+Serif+4:wght@400;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Libre Franklin',sans-serif;color:#1a1a2e;background:#fff;line-height:1.6;-webkit-font-smoothing:antialiased}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
:root{--accent:#c0392b;--charcoal:#1a1a2e;--text:#2c3e50;--muted:#7f8c8d;--light-bg:#f8f9fa;--border:#e8ecef;--serif:'Source Serif 4',Georgia,serif;--sans:'Libre Franklin',sans-serif;--max-w:960px}
.nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(255,255,255,0.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--border)}
.nav-inner{max-width:1140px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:56px}
.nav-back{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:500;color:var(--muted);transition:color .2s}
.nav-back:hover{color:var(--charcoal)}
.nav-back svg{width:16px;height:16px}
.nav-title{font-size:13px;font-weight:600;color:var(--charcoal)}
.page-hero{padding:100px 24px 60px;background:var(--light-bg);border-bottom:1px solid var(--border)}
.page-hero-inner{max-width:var(--max-w);margin:0 auto}
.page-hero-label{font-size:11px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:12px}
.page-hero h1{font-family:var(--serif);font-size:clamp(32px,4vw,44px);font-weight:700;color:var(--charcoal);margin-bottom:16px;letter-spacing:-.02em}
.page-hero p{font-size:17px;color:var(--text);max-width:680px;line-height:1.7}
.hero-stats{display:flex;flex-wrap:wrap;gap:24px;margin-top:28px}
.hero-stat{text-align:center}
.hero-stat-num{font-size:28px;font-weight:700;color:var(--charcoal)}
.hero-stat-label{font-size:11px;color:var(--muted);margin-top:2px}
.content{max-width:var(--max-w);margin:0 auto;padding:60px 24px}
.content h2{font-family:var(--serif);font-size:28px;font-weight:700;color:var(--charcoal);margin:48px 0 16px;letter-spacing:-.01em}
.content h2:first-child{margin-top:0}
.content p{font-size:15px;color:var(--text);line-height:1.8;margin-bottom:16px}
.content-note{background:var(--light-bg);border-left:3px solid var(--accent);padding:16px 20px;border-radius:0 8px 8px 0;margin:24px 0;font-size:14px;color:var(--text);line-height:1.7}
.gallery-section{margin:48px 0}
.gallery-label{font-size:13px;font-weight:600;color:var(--charcoal);margin-bottom:16px;display:flex;align-items:center;gap:8px}
.gallery-label span{font-size:11px;font-weight:500;color:var(--muted)}
.gallery{display:grid;gap:16px}
.gallery-4{grid-template-columns:repeat(4,1fr)}
.gallery img{border-radius:10px;box-shadow:0 2px 12px rgba(0,0,0,0.08);cursor:zoom-in;transition:transform .25s,box-shadow .25s}
.gallery img:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,0.12)}
.gallery-caption{font-size:11px;color:var(--muted);text-align:center;margin-top:6px}
.dashboard-section{margin:48px 0;background:var(--light-bg);border-radius:12px;overflow:hidden;border:1px solid var(--border)}
.dashboard-header{padding:20px 24px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border)}
.dashboard-header h3{font-size:16px;font-weight:700;color:var(--charcoal)}
.dashboard-header a{font-size:12px;font-weight:600;color:var(--accent);display:flex;align-items:center;gap:4px}
.dashboard-embed{width:100%;height:70vh;min-height:500px;border:none}
.video-section{margin:48px 0}
.video-wrap{position:relative;padding-bottom:56.25%;height:0;border-radius:12px;overflow:hidden;background:#000}
.video-wrap iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:none}
.video-caption{font-size:12px;color:var(--muted);margin-top:8px;text-align:center}
.third-party-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin:24px 0}
.tp-card{background:var(--light-bg);border-radius:12px;overflow:hidden;border:1px solid var(--border)}
.tp-card img{width:100%;aspect-ratio:9/16;object-fit:cover;object-position:top}
.tp-card-info{padding:16px}
.tp-card-title{font-size:15px;font-weight:700;color:var(--charcoal);margin-bottom:4px}
.tp-card-desc{font-size:13px;color:var(--muted);line-height:1.5}
.figma-btn{display:inline-flex;align-items:center;gap:8px;padding:10px 20px;background:#1a1a2e;color:#fff;border-radius:8px;font-size:13px;font-weight:600;margin-top:12px;transition:background .2s}
.figma-btn:hover{background:var(--accent)}
.lightbox{display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,0.92);align-items:center;justify-content:center;cursor:zoom-out}
.lightbox.active{display:flex}
.lightbox img{max-width:90vw;max-height:90vh;border-radius:8px}
.lightbox-close{position:absolute;top:20px;right:24px;color:#fff;font-size:28px;cursor:pointer;opacity:.7}
.lightbox-close:hover{opacity:1}
.lightbox-nav{position:absolute;top:50%;transform:translateY(-50%);color:#fff;font-size:36px;cursor:pointer;opacity:.6;padding:20px;user-select:none}
.lightbox-nav:hover{opacity:1}
.lightbox-prev{left:12px}
.lightbox-next{right:12px}
@media(max-width:768px){
  .gallery-4{grid-template-columns:repeat(2,1fr)}
  .third-party-grid{grid-template-columns:1fr}
  .hero-stats{gap:16px}
  .hero-stat-num{font-size:22px}
  .dashboard-embed{height:50vh;min-height:400px}
}
@media(max-width:480px){.gallery-4{grid-template-columns:1fr 1fr}}
</style>
</head>
<body>

<nav class="nav">
  <div class="nav-inner">
    <a href="index.html#littech" class="nav-back">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
      Back to Portfolio
    </a>
    <div class="nav-title">{{ littechPage.navTitle }}</div>
  </div>
</nav>

<header class="page-hero">
  <div class="page-hero-inner">
    <div class="page-hero-label">{{ littechPage.heroLabel }}</div>
    <h1>{{ littechPage.heroTitle }}</h1>
    <p>{{ littechPage.heroDesc }}</p>
    <div class="hero-stats">
      {%- for s in littechPage.heroStats %}
      <div class="hero-stat"><div class="hero-stat-num">{{ s.value }}</div><div class="hero-stat-label">{{ s.label }}</div></div>
      {%- endfor %}
    </div>
  </div>
</header>

<div class="content">

  <h2>Context</h2>
  <p>{{ littechPage.context.para1 }}</p>
  <p>{{ littechPage.context.para2 }}</p>

  <h2>{{ littechPage.consumerApp.title }}</h2>
  <p>{{ littechPage.consumerApp.para1 }}</p>
  <p>{{ littechPage.consumerApp.para2 }}</p>

  <div class="gallery-section">
    <div class="gallery-label">{{ littechPage.consumerApp.galleryLabel }} <span>(click to enlarge)</span></div>
    <div class="gallery gallery-4" id="gallery-consumer">
      {%- for s in littechPage.consumerApp.screenshots %}
      <div><img src="{{ s.src }}" alt="{{ s.alt }}" onclick="openLightbox({{ loop.index0 }},'consumer')"><div class="gallery-caption">{{ s.caption }}</div></div>
      {%- endfor %}
    </div>
  </div>

  <h2>{{ littechPage.deliveryApp.title }}</h2>
  <p>{{ littechPage.deliveryApp.description }}</p>

  <div class="gallery-section">
    <div class="gallery-label">{{ littechPage.deliveryApp.galleryLabel }} <span>(click to enlarge)</span></div>
    <div class="gallery gallery-4" id="gallery-delivery">
      {%- for s in littechPage.deliveryApp.screenshots %}
      <div><img src="{{ s.src }}" alt="{{ s.alt }}" onclick="openLightbox({{ loop.index0 }},'delivery')"><div class="gallery-caption">{{ s.caption }}</div></div>
      {%- endfor %}
    </div>
  </div>

  <div class="video-section">
    <h2>{{ littechPage.video.title }}</h2>
    <div class="video-wrap">
      <iframe src="https://www.youtube.com/embed/{{ littechPage.video.youtubeId }}" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture" allowfullscreen title="{{ littechPage.video.title }}" loading="lazy"></iframe>
    </div>
    <div class="video-caption">{{ littechPage.video.caption }}</div>
  </div>

  <h2>{{ littechPage.dashboard.title }}</h2>
  <p>{{ littechPage.dashboard.description }}</p>
  <div class="content-note"><strong>Note on numbers:</strong> {{ littechPage.dashboard.note }}</div>
  <div class="dashboard-section">
    <div class="dashboard-header">
      <h3>Kirana B2B Sales Dashboard — Trivandrum</h3>
      <a href="dashboard.html" target="_blank">Open Full Screen ↗</a>
    </div>
    <iframe class="dashboard-embed" src="dashboard.html" title="Lit Technologies Sales Dashboard" loading="lazy"></iframe>
  </div>

  <h2>Additional Design Projects</h2>
  <p>During the Lit Technologies period, also led design for two third-party projects — extending the team's capabilities to new domains during the pandemic to maintain cashflow and expand the portfolio.</p>
  <div class="third-party-grid">
    {%- for p in littechPage.thirdPartyProjects %}
    <div class="tp-card">
      <img src="{{ p.image }}" alt="{{ p.title }}">
      <div class="tp-card-info">
        <div class="tp-card-title">{{ p.title }}</div>
        <div class="tp-card-desc">{{ p.description }}</div>
        {% if p.link %}
        <a href="{{ p.link }}" target="_blank" class="figma-btn">{{ p.linkText }}</a>
        {% endif %}
      </div>
    </div>
    {%- endfor %}
  </div>

  <h2>{{ littechPage.acquisition.title }}</h2>
  <p>{{ littechPage.acquisition.para1 }}</p>
  <p>{{ littechPage.acquisition.para2 }}</p>

  <div style="margin-top:48px;padding-top:32px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px">
    <a href="index.html#littech" style="font-size:14px;font-weight:600;color:var(--muted);display:flex;align-items:center;gap:6px">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:16px;height:16px"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
      Back to Portfolio
    </a>
    <a href="ondc.html" style="font-size:14px;font-weight:600;color:var(--accent);display:flex;align-items:center;gap:6px">
      Next: ONDC Case Study
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:16px;height:16px"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
    </a>
  </div>

</div>

<div class="lightbox" id="lightbox" onclick="closeLightbox()">
  <span class="lightbox-close">✕</span>
  <span class="lightbox-nav lightbox-prev" onclick="event.stopPropagation();navLightbox(-1)">‹</span>
  <img id="lightbox-img" src="" alt="">
  <span class="lightbox-nav lightbox-next" onclick="event.stopPropagation();navLightbox(1)">›</span>
</div>

<script>
const galleries={
  consumer:[...document.querySelectorAll('#gallery-consumer img')].map(i=>i.src),
  delivery:[...document.querySelectorAll('#gallery-delivery img')].map(i=>i.src)
};
let currentGallery='',currentIdx=0;
function openLightbox(idx,gallery){
  currentGallery=gallery;currentIdx=idx;
  document.getElementById('lightbox-img').src=galleries[gallery][idx];
  document.getElementById('lightbox').classList.add('active');
  document.body.style.overflow='hidden';
}
function closeLightbox(){
  document.getElementById('lightbox').classList.remove('active');
  document.body.style.overflow='';
}
function navLightbox(dir){
  const g=galleries[currentGallery];
  currentIdx=(currentIdx+dir+g.length)%g.length;
  document.getElementById('lightbox-img').src=g[currentIdx];
}
document.addEventListener('keydown',e=>{
  if(e.key==='Escape')closeLightbox();
  if(e.key==='ArrowRight')navLightbox(1);
  if(e.key==='ArrowLeft')navLightbox(-1);
});
</script>
</body>
</html>
